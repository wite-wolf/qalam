{
  "name": "qalam-whiteboard",
  "version": "1.0.0",
  "description": "السبورة البيضاء الذكية - تطبيق قلم",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack:win": "npx @electron/packager . \"قلم\" --platform=win32 --arch=x64 --icon=logo.ico --out=dist --overwrite --asar --no-prune",
    "build:www": "node -e \"const f=require('fs');const p=f.existsSync('www')&&f.rmSync('www',{recursive:true});f.mkdirSync('www');['app.html','logo.png','logo.ico','manifest.json','sw.js'].forEach(x=>f.copyFileSync(x,'www/'+x));f.cpSync('css','www/css',{recursive:true});f.cpSync('js','www/js',{recursive:true});f.copyFileSync('app.html','www/index.html');console.log('www built');\"",
    "build:android": "npm run build:www && npx cap sync android",
    "build:apk": "npm run build:android && cd android && gradlew assembleDebug"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@electron/packager": "^20.0.1",
    "electron": "^33.0.0",
    "ico-endec": "^0.1.6",
    "jimp": "^1.6.1",
    "rcedit": "^5.0.2",
    "wrangler": "^4.99.0"
  }
}
